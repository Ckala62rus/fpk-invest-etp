# Docker Compose — порты и сервисы
# Скопируй в .env: copy .env.example .env

COMPOSE_PROJECT_NAME=etp

NGINX_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379
PGADMIN_PORT=8081

POSTGRES_DB=etp
POSTGRES_USER=etp
POSTGRES_PASSWORD=etp

PGADMIN_DEFAULT_EMAIL=admin@etp.local
PGADMIN_DEFAULT_PASSWORD=admin

# Xdebug (передаётся в контейнер backend-etp, не в Laravel)
XDEBUG_MODE=develop,debug
XDEBUG_CONFIG=client_host=host.docker.internal client_port=9003
PHP_IDE_CONFIG=serverName=etp
